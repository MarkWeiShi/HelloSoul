# ============================================================
# Character_Image_Gen - Environment Variables
# ============================================================
# Usage:
# 1. Copy this file to .env
#    cp .env.example .env
# 2. Fill your keys
# 3. Keep .env out of git

# Google Gemini API Key (required)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Jimeng key (optional, needed for workflow.py step4 video)
# https://www.jimeng.com/ or https://console.volcengine.com/
JIMENG_API_KEY=

# Ark key (optional, needed for test_video.py / gen_videos.py)
# https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
ARK_API_KEY=
