# Backend environment template
# Copy to .env before local run:
#   cp backend/.env.example backend/.env

# App
PORT=3001
JWT_SECRET=replace_with_a_secure_secret

# Prisma (SQLite)
DATABASE_URL="file:../prisma/dev.db"

# LLM provider (choose one mode)
# Mode A: Official Anthropic direct API
ANTHROPIC_API_KEY=

# Mode B: Gateway/proxy mode (example: custom base URL + bearer token)
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# Optional: ElevenLabs TTS
ELEVENLABS_API_KEY=
AKARI_VOICE_ID=EXAVITQu4vr4xnSDxMaL
